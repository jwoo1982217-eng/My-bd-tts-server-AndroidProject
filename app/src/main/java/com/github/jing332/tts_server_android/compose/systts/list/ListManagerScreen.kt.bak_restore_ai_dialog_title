                                    isFabExpanded = false
                                    isFabTucked = true
                                    isBatchEditMode = true
                                }
                            ) {
                                Text("✏️")
                            }

                            IconButton(onClick = { showOptions = true }) {
                                Icon(
                                    Icons.Default.MoreVert,
                                    stringResource(id = R.string.more_options)
                                )
                                MenuMoreOptions(
                                    expanded = showOptions,
                                    onDismissRequest = { showOptions = false },
                                    onExportAll = {
                                        showGroupExportSheet = models.flatMap { it.toExportList() }
                                    },
                                )
                            }
                        }
                    }
                }
            )
        },
    ) { paddingValues ->
        Box(Modifier.padding(top = paddingValues.calculateTopPadding())) {
            ControlBottomBarVisibility(listState, LocalBottomBarBehavior.current)

            LazyColumn(
                Modifier
                    .fillMaxSize()
                    .then(
                        if ((!isSearchMode || inputSearchKeyword.isBlank()) && !isBatchEditMode) {
                            Modifier.reorderable(state = reorderState)
                        } else {
                            Modifier
                        }
                    ),
                state = listState
            ) {
                if (isBatchEditMode) {
                    models.forEach { node ->
                        batchGroupTreeNode(node)
                    }
                } else if (!isSearchMode || inputSearchKeyword.isBlank()) {
                    models.forEach { node ->
                        groupTreeNode(node)
                    }
                } else if (!canSearchInput) {
                    item(key = "search_tip") {
                        Text(
                            text = "🔍 请输入至少 2 个字；数字编号可直接搜索",
                            modifier = Modifier.padding(horizontal = 16.dp, vertical = 8.dp)
                        )
                    }
                } else {
                    item(key = "search_result_count") {
                        Text(
                            text = "🔍 搜索结果：${searchResults.size}，最多显示前 50 个",
                            modifier = Modifier.padding(horizontal = 16.dp, vertical = 4.dp)
                        )
                    }

                    searchResults.forEach { result ->
                        searchTtsItem(
                            item = result.tts,
                            groupLevel = 0,
                            keyPrefix = "search_${result.group.id}"
                        )
                    }
                }

                item {
                    Spacer(Modifier.padding(bottom = AppDefaultProperties.LIST_END_PADDING))
                }
            }

            if (!isSearchMode && inputSearchKeyword.isBlank() && !isBatchEditMode) {
                val density = LocalDensity.current

                var ballOffsetX by rememberSaveable { mutableStateOf(0f) }
                var ballOffsetY by rememberSaveable { mutableStateOf(0f) }

                fun closeFloatingMenu() {
                    isFabExpanded = false
                    isFabTucked = true
                }

                fun itemOffset(xDp: Int, yDp: Int): IntOffset {
                    return IntOffset(
                        x = ballOffsetX.roundToInt() + with(density) { xDp.dp.roundToPx() },
                        y = ballOffsetY.roundToInt() + with(density) { yDp.dp.roundToPx() }
                    )
                }

                if (isFabExpanded) {
                    Box(
                        modifier = Modifier
                            .align(Alignment.BottomEnd)
                            .padding(end = 18.dp, bottom = 24.dp)
                            .offset {
                                itemOffset(-96, -30)
                            }
                    ) {
                        Column(
                            horizontalAlignment = Alignment.End
                        ) {
                            SideMenuButton(
                                text = "角色管理",
                                onClick = {
                                    closeFloatingMenu()

                                    val allTts = models.collectAllTts()

                                    val target = allTts
                                        .firstOrNull { item ->
                                            item.displayName.trim() == "角色管理"
                                        }
                                        ?: allTts.firstOrNull { item ->
                                            val config = item.config as? TtsConfigurationDTO
                                            val source = config?.source as? PluginTtsSource

                                            source?.pluginId == "mingwuyan" &&
                                                    config.speechRule.tagRuleId == "mingwuyan"
                                        }
                                        ?: allTts.firstOrNull { item ->
                                            val descriptor = ItemDescriptorFactory.from(context, item)
                                            descriptor.tagName.toString().contains("在线音效")
                                        }

                                    if (target != null) {
                                        navigateToEdit(target)
                                    } else {
                                        context.toast("未找到「角色管理」配置")
                                    }
                                }
                            )

                            Spacer(Modifier.height(8.dp))

                            SideMenuButton(
                                text = "添加本地",
                                onClick = {
                                    closeFloatingMenu()
                                    navigateToEdit(
                                        SystemTtsV2(
                                            config = TtsConfigurationDTO(
                                                source = LocalTtsSource(locale = AppConst.localeCode)
                                            )
                                        )
                                    )
                                }
                            )

                            Spacer(Modifier.height(8.dp))

                            SideMenuButton(
                                text = "添加插件",
                                onClick = {
                                    closeFloatingMenu()
                                    addPluginDialog = true
                                }
                            )

                            Spacer(Modifier.height(8.dp))

                            SideMenuButton(
                                text = "添加分组",
                                onClick = {
                                    closeFloatingMenu()
                                    addGroupParentId = 0L
                                    addGroupDialog = true
                                }
                            )

                            Spacer(Modifier.height(8.dp))

                            SideMenuButton(
                                text = "添加BGM",
                                onClick = {
                                    closeFloatingMenu()
                                    navigateToEdit(SystemTtsV2(config = BgmConfiguration()))
                                }
                            )
                        }
                    }
                }

                FloatingActionButton(
                    modifier = Modifier
                        .align(Alignment.BottomEnd)
                        .padding(end = 18.dp, bottom = 24.dp)
                        .offset {
                            IntOffset(
                                x = ballOffsetX.roundToInt(),
                                y = ballOffsetY.roundToInt()
                            )
                        }
                        .size(58.dp)
                        .pointerInput(Unit) {
                            detectDragGestures { _, dragAmount ->
                                ballOffsetX += dragAmount.x
                                ballOffsetY += dragAmount.y
                            }
                        },
                    shape = CircleShape,
                    onClick = {
                        isFabExpanded = !isFabExpanded
                        isFabTucked = !isFabExpanded
                    }
                ) {
                    Text(
                        text = if (isFabExpanded) "×" else "☰",
                        fontSize = 24.sp
                    )
                }
            }

            LaunchedEffect(key1 = Unit) {
                withIO {
                    vm.checkListData(context)
                }
            }
        }
    }
}