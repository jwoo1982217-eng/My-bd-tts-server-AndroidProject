                }

                context.longToast(
                    "已移动 ${selectedGroupNodes.size} 个分组，${selectedDirectTtsList.size} 个音色到 ${targetGroup.name}"
                )

                exitBatchEditMode()
            }
        }
    )
}

    if (showBatchDeleteDialog) {
        AlertDialog(
            onDismissRequest = { showBatchDeleteDialog = false },
            title = {
                Text(text = "确认删除")
            },
            text = {
                Text(
                    text = "确定删除选中的 $selectedCount 项吗？\n\n删除分组会同时删除该分组下的所有子分组和音色。"
                )
            },
            confirmButton = {
                TextButton(
                    onClick = {
                        showBatchDeleteDialog = false

                        val rootNodesToDelete = models.selectedRootNodes()
                        val groupNodesToDelete = rootNodesToDelete.flatMap { it.flattenNodes() }
                        val ttsFromGroups = rootNodesToDelete.flatMap { it.collectAllTts() }

                        val ttsIdsFromGroups = ttsFromGroups.map { it.id }.toSet()
                        val directlySelectedTts = models.collectAllTts()
                            .filter { selectedTtsIds.contains(it.id) && !ttsIdsFromGroups.contains(it.id) }

                        val ttsToDelete = (ttsFromGroups + directlySelectedTts)
                            .distinctBy { it.id }
                            .filter { it.id !in excludedTtsIds }

                        val groupNodesDeleteOrder = groupNodesToDelete.asReversed()

                        scope.launch {
                            withIO {
                                if (ttsToDelete.isNotEmpty()) {
                                    dbm.systemTtsV2.delete(*ttsToDelete.toTypedArray())
                                }

                                groupNodesDeleteOrder.forEach { node ->
                                    dbm.systemTtsV2.deleteGroup(node.group)
                                }
                            }

                            if (ttsToDelete.any { it.isEnabled }) {
                                SystemTtsService.notifyUpdateConfig()
                            }

                            context.longToast("已删除 ${ttsToDelete.size} 个音色，${groupNodesToDelete.size} 个分组")
                            exitBatchEditMode()
