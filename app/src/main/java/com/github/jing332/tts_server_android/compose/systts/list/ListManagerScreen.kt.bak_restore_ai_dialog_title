    fun LazyListScope.batchGroupTreeNode(
        node: GroupTreeNode,
        level: Int = 0,
        parentSelected: Boolean = false,
    ) {
        val g = node.group
        val key = "batch_g_${g.id}"
        val selfSelected = selectedGroupIds.contains(g.id)
        val branchSelected = parentSelected || selfSelected

        stickyHeader(key = key) {
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .clickable {
                        vm.updateGroupExpanded(g, !g.isExpanded)
                    }
                    .padding(
                        start = (level * 20).dp,
                        end = 8.dp,
                        top = 6.dp,
                        bottom = 6.dp
                    ),
                verticalAlignment = Alignment.CenterVertically
            ) {
                Checkbox(
                    checked = branchSelected,
                    onCheckedChange = { checked ->
                        val idsInThisGroup = node.collectAllTts().map { it.id }.toSet()

                        selectedGroupIds =
                            if (checked) {
                                selectedGroupIds + g.id
                            } else {
                                selectedGroupIds - g.id
                            }

                        // 重新勾选文件夹时，之前单独取消的音色应恢复选中；
                        // 取消文件夹时，也清理这个分组下的排除状态。
                        excludedTtsIds = excludedTtsIds - idsInThisGroup
                    }
                )

                Text(
                    text = if (g.isExpanded) {
                        "📂 ${g.name}"
                    } else {
                        "📁 ${g.name}"
                    },
                    modifier = Modifier.weight(1f),
                    style = MaterialTheme.typography.titleMedium
                )

                Text(
                    text = if (g.isExpanded) "收起" else "展开",
                    color = MaterialTheme.colorScheme.primary,
                    modifier = Modifier.padding(horizontal = 8.dp)
                )
            }
        }

        if (g.isExpanded) {
            itemsIndexed(
                node.list.sortedBy { it.order },
                key = { _, item -> "batch_${g.id}_${item.id}" }
            ) { _, item ->
                val descriptor = remember(item) {
                    ItemDescriptorFactory.from(context, item)
                }

                val itemSelectedByGroup = branchSelected
                val itemSelectedDirectly = selectedTtsIds.contains(item.id)
                val itemExcluded = excludedTtsIds.contains(item.id)
                val itemSelected = (itemSelectedByGroup && !itemExcluded) || itemSelectedDirectly

                Row(
                    modifier = Modifier
                        .fillMaxWidth()
                        .clickable {
                            if (itemSelectedByGroup) {
                                if (itemExcluded) {
                                    excludedTtsIds = excludedTtsIds - item.id
                                } else {
                                    excludedTtsIds = excludedTtsIds + item.id
                                    selectedTtsIds = selectedTtsIds - item.id
                                }
                            } else {
                                selectedTtsIds =
                                    if (selectedTtsIds.contains(item.id)) {
                                        selectedTtsIds - item.id
                                    } else {
                                        selectedTtsIds + item.id
                                    }
                            }
                        }
                        .padding(
                            start = 8.dp,
                            end = 8.dp,
                            top = 4.dp,
                            bottom = 4.dp
                        ),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Checkbox(
                        checked = itemSelected,
                        onCheckedChange = { checked ->
                            if (itemSelectedByGroup) {
                                if (checked) {
                                    excludedTtsIds = excludedTtsIds - item.id
                                } else {
                                    excludedTtsIds = excludedTtsIds + item.id
                                    selectedTtsIds = selectedTtsIds - item.id
                                }
                            } else {
                            selectedTtsIds =
                                if (checked) {
                                    selectedTtsIds + item.id
                                } else {
                                    selectedTtsIds - item.id
                                }
                        }
                        }
                    )

                    Column(
                        modifier = Modifier.weight(1f)
                    ) {
                        Text(
                            text = "🎙️ ${item.displayName}",
                            style = MaterialTheme.typography.bodyLarge
                        )

                        Text(
                            text = listOf(
                                descriptor.tagName,
                                descriptor.bottom
                            ).filter {
                                it.toString().isNotBlank()
                            }.joinToString("  |  "),
                            style = MaterialTheme.typography.bodySmall,
                            color = MaterialTheme.colorScheme.onSurfaceVariant
                        )
                    }
                }
            }

            node.children.forEach { child ->
                batchGroupTreeNode(
                    node = child,
                    level = level + 1,
                    parentSelected = branchSelected
                )
            }
        }
    }

    fun LazyListScope.groupTreeNode(
        node: GroupTreeNode,
        level: Int = 0,
    ) {
        val g = node.group
        val allTts = node.allTts()
        val checkState = allTts.count { it.isEnabled }.sizeToToggleableState(allTts.size)
        val key = "g_${g.id}"

        item(key = key) {
    ShadowedDraggableItem(reorderableState = reorderState, key = key) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .detectReorderAfterLongPress(reorderState),
            verticalAlignment = Alignment.CenterVertically
        ) {
            val hasAutoTagButton = autoTagRuleByGroupName(g.name) != null

            if (hasAutoTagButton) {
                IconButton(
                    modifier = Modifier.padding(start = (level * 20).dp),
                    onClick = {
                        autoTagAndSortGroup(node)
                    }
                ) {
                    Text("🏷️")
                }
            }

            Group(
                modifier = Modifier
                    .weight(1f)
                    .padding(start = if (hasAutoTagButton) 0.dp else (level * 20).dp),
                name = g.name,
                isExpanded = g.isExpanded,
                toggleableState = checkState,
                onToggleableStateChange = {
                    vm.updateGroupEnable(node, it)
                },
                onClick = {
                    vm.updateGroupExpanded(g, !g.isExpanded)
                },
                onDelete = {
                    fun deleteNode(target: GroupTreeNode) {
                        target.children.forEach { deleteNode(it) }
                        dbm.systemTtsV2.delete(*target.list.toTypedArray())
                        dbm.systemTtsV2.deleteGroup(target.group)
                    }

                    deleteNode(node)
                },
                onRename = {
                    dbm.systemTtsV2.updateGroup(g.copy(name = it))
                },
                onCopy = {
                    scope.launch {
                        val group = g.copy(
                            id = System.currentTimeMillis(),
                            name = it.ifBlank { context.getString(R.string.unnamed) },
                            parentGroupId = g.parentGroupId
                        )

                        dbm.systemTtsV2.insertGroup(group)

                        dbm.systemTtsV2.getByGroup(g.id)
                            .forEachIndexed { index, tts ->
                                dbm.systemTtsV2.insert(
                                    tts.copy(
                                        id = System.currentTimeMillis() + index,
                                        groupId = group.id
