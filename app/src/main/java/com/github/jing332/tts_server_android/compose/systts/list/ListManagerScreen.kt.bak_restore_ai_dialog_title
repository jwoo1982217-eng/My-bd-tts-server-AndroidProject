    val models by vm.list.collectAsStateWithLifecycle()

    fun GroupTreeNode.flattenNodes(): List<GroupTreeNode> {
        return listOf(this) + children.flatMap { it.flattenNodes() }
    }

    fun GroupTreeNode.collectAllTts(): List<SystemTtsV2> {
        return list + children.flatMap { it.collectAllTts() }
    }

    fun List<GroupTreeNode>.flattenNodes(): List<GroupTreeNode> {
        return flatMap { it.flattenNodes() }
    }

    fun List<GroupTreeNode>.collectAllTts(): List<SystemTtsV2> {
        return flatMap { it.collectAllTts() }
    }

    fun List<GroupTreeNode>.selectedRootNodes(): List<GroupTreeNode> {
        fun collect(node: GroupTreeNode): List<GroupTreeNode> {
            if (selectedGroupIds.contains(node.group.id)) {
                return listOf(node)
            }
            return node.children.flatMap { collect(it) }
        }

        return flatMap { collect(it) }
    }

    fun getBatchSelectedTtsList(): List<SystemTtsV2> {
        val rootNodesToHandle = models.selectedRootNodes()
        val ttsFromGroups = rootNodesToHandle.flatMap { it.collectAllTts() }

        val ttsIdsFromGroups = ttsFromGroups.map { it.id }.toSet()

        val directlySelectedTts = models.collectAllTts()
            .filter { selectedTtsIds.contains(it.id) && !ttsIdsFromGroups.contains(it.id) }

        return (ttsFromGroups + directlySelectedTts)
            .distinctBy { it.id }
            .filter { it.id !in excludedTtsIds }
    }
    
    fun List<GroupTreeNode>.batchMoveTargetOptions(): List<GroupMoveOption> {
    val blockedGroupIds = selectedRootNodes()
        .flatMap { it.flattenNodes() }
        .map { it.group.id }
        .toSet()

    return flattenGroupOptions(this)
        .filter { it.group.id !in blockedGroupIds }
}

fun getDirectSelectedTtsForBatchMove(): List<SystemTtsV2> {
    val selectedGroupTtsIds = models.selectedRootNodes()
        .flatMap { it.collectAllTts() }
        .map { it.id }
        .toSet()

    return models.collectAllTts()
        .filter {
            selectedTtsIds.contains(it.id) &&
                    it.id !in selectedGroupTtsIds
        }
}

    fun switchSelectedTtsPluginId(
        newPluginId: String,
        resetVoice: Boolean,
    ) {
        if (newPluginId.isBlank()) {
            context.toast("插件ID为空")
            return
        }

        val selectedTtsList = getBatchSelectedTtsList()

        if (selectedTtsList.isEmpty()) {
            context.toast("请先选择要切换的音色")
            return
        }

        val targetPlugin = dbm.pluginDao.getEnabled(newPluginId)
            ?: dbm.pluginDao.getByPluginId(newPluginId)

        if (targetPlugin == null) {
            context.toast("目标插件不存在：$newPluginId")
            return
        }

        val targetSampleRate = resolvePluginSampleRate(targetPlugin)
        val targetNeedDecode = resolvePluginNeedDecode(targetPlugin)

        val updatedList = selectedTtsList.mapNotNull { tts ->
            val config = tts.config as? TtsConfigurationDTO ?: return@mapNotNull null
            val source = config.source as? PluginTtsSource ?: return@mapNotNull null

            val migratedVoice = if (resetVoice) {
                ""
            } else {
                resolveVoiceIdForCurrentPlugin(
                    displayName = tts.displayName,
                    oldVoiceId = source.voice,
                    targetPlugin = targetPlugin
                )
            }

            val newSource = if (resetVoice) {
                source.copy(
                    pluginId = newPluginId,
                    locale = "",
                    voice = ""
                )
            } else {
                source.copy(
                    pluginId = newPluginId,
                    voice = migratedVoice
                )
            }

            if (source.pluginId == newSource.pluginId &&
                source.locale == newSource.locale &&
                source.voice == newSource.voice &&
                config.audioFormat.sampleRate == targetSampleRate &&
                config.audioFormat.isNeedDecode == targetNeedDecode
            ) {
                return@mapNotNull null
            }

            tts.copy(
                config = config.copy(
                    source = newSource,
                    audioFormat = config.audioFormat.copy(
                        sampleRate = targetSampleRate,
                        isNeedDecode = targetNeedDecode
                    )
                )
            )
        }

        if (updatedList.isEmpty()) {
            context.toast("没有需要重新适配的插件TTS")
            return
        }

        scope.launch {
            withIO {
                dbm.systemTtsV2.update(*updatedList.toTypedArray())
            }

            if (updatedList.any { it.isEnabled }) {
                SystemTtsService.notifyUpdateConfig()
            }

            context.longToast("已切换 ${updatedList.size} 个音色到插件：$newPluginId")
            exitBatchEditMode()
        }
    }

if (showBatchMoveDialog) {
    val selectedGroupNodes = models.selectedRootNodes()
    val selectedDirectTtsList = getDirectSelectedTtsForBatchMove()
    val targetGroups = models.batchMoveTargetOptions()

    BatchMoveDialog(
