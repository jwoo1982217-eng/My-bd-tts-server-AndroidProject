    }

    val pluginFlow = remember { dbm.pluginDao.flowAll().conflate() }
    val pluginList by pluginFlow.collectAsStateWithLifecycle(emptyList())
    val pluginNameMap = remember(pluginList) {
        pluginList.associate { it.pluginId to it.name }
