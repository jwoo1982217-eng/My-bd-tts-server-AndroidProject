            }
        } else {
            dbm.speechRuleDao.getByRuleId(ruleData.tagRuleId)?.let {
                ruleData.target = SpeechTarget.TAG
                ruleData.tag = it.tags.keys.first()
            }
        }

        dbm.systemTtsV2.update(systts.copy(config = systts.ttsConfig.copy(speechRule = ruleData)))
        if (systts.isEnabled) {
            SystemTtsService.notifyUpdateConfig()
        }
    }

  fun autoTagAndSortGroup(node: GroupTreeNode) {
    val groupRule = autoTagRuleByGroupName(node.group.name)

    if (groupRule == null) {
        context.toast("分组名未匹配到自动标签规则")
        return
    }

    val targetList = node.list
        .sortedBy { it.order }
        .filter { it.config is TtsConfigurationDTO }

    if (targetList.isEmpty()) {
        context.toast("这个分组没有可处理的插件音色")
        return
    }

    scope.launch {
        var successCount = 0
        var skipCount = 0

        val workList = targetList.mapIndexed { originalIndex, item ->
            AutoTagWorkItem(
                originalIndex = originalIndex,
                item = item,
                rule = groupRule
            )
        }

        withIO {
            var newOrder = 0

            workList.forEachIndexed { indexInGroup, work ->
                val item = work.item
                val config = item.config as TtsConfigurationDTO
                val oldSpeechRule = config.speechRule

                val speechRule = findSpeechRuleForAutoTag(
                    oldRuleId = oldSpeechRule.tagRuleId,
                    autoRule = groupRule,
                    index = indexInGroup
                )

                if (speechRule == null) {
                    skipCount++
                    return@forEachIndexed
                }

                val targetTag = findAutoTagKey(
                    speechRule = speechRule,
                    rule = groupRule,
                    index = indexInGroup
                )

                if (targetTag == null) {
                    skipCount++
                    return@forEachIndexed
                }

                val personality = getAutoTagPersonality(item)

                val newTagData = buildAutoTagData(
                    speechRule = speechRule,
                    tag = targetTag,
                    oldTagData = oldSpeechRule.tagData,
                    personality = personality
                )

                var newSpeechRule = oldSpeechRule.copy(
                    target = SpeechTarget.TAG,
                    tagRuleId = speechRule.ruleId,
                    tag = targetTag,
                    tagData = newTagData,
                    tagName = ""
                )

                val generatedTagName = runCatching {
                    SpeechRuleEngine.getTagName(
                        context,
                        speechRule,
                        info = newSpeechRule
                    )
                }.getOrElse {
                    ""
                }

                val finalTagName = generatedTagName.ifBlank {
                    speechRule.tags[targetTag].orEmpty()
                }

                if (finalTagName.isBlank()) {
                    skipCount++
                    return@forEachIndexed
                }

                newSpeechRule = newSpeechRule.copy(
                    tagName = finalTagName
                )

                dbm.systemTtsV2.update(
                    item.copy(
                        order = newOrder,
                        config = config.copy(
                            speechRule = newSpeechRule
                        )
                    )
                )

                newOrder++
                successCount++
            }
        }

        if (targetList.any { it.isEnabled }) {
            SystemTtsService.notifyUpdateConfig()
        }

        if (skipCount > 0) {
            context.longToast("已整理 $successCount 个，跳过 $skipCount 个：朗读规则里没有对应标签")
        } else {
            context.longToast("已按分组「${node.group.name}」整理：$successCount 个音色")
        }
    }
}
