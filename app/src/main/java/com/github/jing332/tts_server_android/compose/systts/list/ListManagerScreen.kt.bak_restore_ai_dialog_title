            },
            title = {
                Text("批量切换插件")
            },
            text = {
                Column {
                    Text(
                        text = "选择目标插件。保留声音适合同源插件；重选声音会清空语言和声音。",
                        style = MaterialTheme.typography.bodySmall,
                        color = MaterialTheme.colorScheme.onSurfaceVariant
                    )

                    if (pluginList.isEmpty()) {
                        Text(
                            text = "当前没有可用插件",
                            modifier = Modifier.padding(top = 12.dp)
                        )
                    } else {
                        LazyColumn(
                            modifier = Modifier
                                .fillMaxWidth()
                                .heightIn(max = 420.dp)
                                .padding(top = 8.dp)
                        ) {
                            itemsIndexed(
                                pluginList,
                                key = { _, plugin -> plugin.id }
                            ) { _, plugin ->
                                Column(
                                    modifier = Modifier
                                        .fillMaxWidth()
                                        .padding(vertical = 6.dp)
                                ) {
                                    Text(
                                        text = plugin.name.ifBlank { "未命名插件" },
                                        style = MaterialTheme.typography.bodyMedium
                                    )

                                    Text(
                                        text = "pluginId: ${plugin.pluginId}  |  v${plugin.version}",
                                        style = MaterialTheme.typography.bodySmall,
                                        color = MaterialTheme.colorScheme.onSurfaceVariant
                                    )

                                    Row(
                                        modifier = Modifier.fillMaxWidth()
                                    ) {
                                        TextButton(
                                            onClick = {
                                                showSwitchPluginDialog = false
                                                switchSelectedTtsPluginId(
                                                    newPluginId = plugin.pluginId,
                                                    resetVoice = false
                                                )
                                            }
                                        ) {
                                            Text("适配声音")
                                        }

