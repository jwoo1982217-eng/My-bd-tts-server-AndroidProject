    fun LazyListScope.searchTtsItem(
        item: SystemTtsV2,
        groupLevel: Int,
        keyPrefix: String,
    ) {
        item(key = "${keyPrefix}_${item.groupId}_${item.id}") {
            val descriptor = remember(item) {
                ItemDescriptorFactory.from(context, item)
            }

            Item(
                reorderState = reorderState,
                modifier = Modifier.padding(
                    start = 8.dp,
                    end = 8.dp,
                    top = 4.dp,
                    bottom = 4.dp
                ),
                name = item.displayName,
                tagName = descriptor.tagName,
                type = descriptor.type,
                standby = descriptor.standby,
                enabled = item.isEnabled,
                onEnabledChange = {
                    vm.updateTtsEnabled(item, it)
                    if (it) SystemTtsService.notifyUpdateConfig()
                },
                desc = descriptor.desc,
                params = descriptor.bottom,
                onClick = {
                    if (!isBatchEditMode) showQuickEdit = item
                },
                onLongClick = {
                    if (!isBatchEditMode) switchSpeechTarget(item)
                },
                onCopy = {
                    if (!isBatchEditMode) navigateToEdit(item.copy(id = System.currentTimeMillis()))
                },
                onDelete = {
                    if (!isBatchEditMode) deleteTts = item
