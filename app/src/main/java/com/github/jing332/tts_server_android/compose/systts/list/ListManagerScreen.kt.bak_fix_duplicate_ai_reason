                                onClick = {
                                    closeFloatingMenu()
                                    navigateToEdit(
                                        SystemTtsV2(
                                            config = TtsConfigurationDTO(
                                                source = LocalTtsSource(locale = AppConst.localeCode)
                                            )
                                        )
                                    )
                                }
                            )

                            Spacer(Modifier.height(8.dp))

                            SideMenuButton(
                                text = "添加插件",
