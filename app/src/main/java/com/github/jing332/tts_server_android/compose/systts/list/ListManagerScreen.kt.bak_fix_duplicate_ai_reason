private fun autoTagRuleByText(text: String): AutoTagRule? {
    val normalized = normalizeAutoTagText(text).lowercase()

    return AUTO_TAG_RULES.firstOrNull { rule ->
        rule.keywords.any { keyword ->
            normalized.contains(normalizeAutoTagText(keyword).lowercase())
        }
    }
}

private fun autoTagRuleByGroupName(groupName: String): AutoTagRule? {
    val normalized = normalizeAutoTagText(groupName).lowercase()

    // 先按具体关键词命中
    autoTagRuleByText(groupName)?.let { return it }

    // 分组名只有“女”时，只做兜底，不抢少女/女童/女中年/女老年
    if (normalized.contains("女")) {
        return AUTO_TAG_RULES.first {
            it.tagNamePrefix == "女/女青年"
        }
    }

    // 分组名只有“男”时，只做兜底
    if (normalized.contains("男")) {
        return AUTO_TAG_RULES.first {
            it.tagNamePrefix == "男/男青年"
        }
    }

    return null
}

private fun getAutoTagPersonality(systemTts: SystemTtsV2): String {
    val displayName = systemTts.displayName
        .substringBefore("（")
        .substringBefore("(")
        .trim()

    if (displayName.isNotBlank()) {
        return displayName
    }

    val config = systemTts.config as? TtsConfigurationDTO

    return config
        ?.speechRule
        ?.tagData
        ?.get("personality")
        ?.toString()
        ?.trim()
        .orEmpty()
}


private fun normalizeAutoTagText(text: String): String {
    return text
        .replace("\u200B", "")
        .replace("\u200C", "")
        .replace("\u200D", "")
        .replace("\uFEFF", "")
        .replace("【", "")
        .replace("】", "")
        .replace("[", "")
        .replace("]", "")
        .replace(" ", "")
        .trim()
}

private fun findAutoTagKey(
    speechRule: SpeechRule,
    rule: AutoTagRule,
    index: Int,
): String? {
    val number = "%02d".format(index + 1)

    val expectedCore = if (rule.needNumber) {
        "${rule.tagNamePrefix}$number"
    } else {
        rule.tagNamePrefix
    }

    val expectedShort = if (rule.needNumber) {
        "${rule.tagPrefix}$number"
    } else {
        rule.tagPrefix
    }

    val nExpectedCore = normalizeAutoTagText(expectedCore)
    val nExpectedShort = normalizeAutoTagText(expectedShort)

    return speechRule.tags.entries.firstOrNull { entry ->
        val key = entry.key
        val value = entry.value

        val nKey = normalizeAutoTagText(key)
        val nValue = normalizeAutoTagText(value)

        key == expectedShort ||
                key == expectedCore ||
                nKey == nExpectedShort ||
                nKey == nExpectedCore ||
                nValue == nExpectedCore ||
                nValue == nExpectedShort ||
                nValue.startsWith(nExpectedCore) ||
                nValue.startsWith(nExpectedShort) ||
                nValue.contains(nExpectedCore) ||
                nValue.contains(nExpectedShort)
    }?.key
}

private fun findSpeechRuleForAutoTag(
    oldRuleId: String,
    autoRule: AutoTagRule,
    index: Int,
): SpeechRule? {
    val oldRule = dbm.speechRuleDao.getByRuleId(oldRuleId)

    if (oldRule != null && findAutoTagKey(oldRule, autoRule, index) != null) {
        return oldRule
    }

    return dbm.speechRuleDao.allEnabled.firstOrNull { rule ->
        findAutoTagKey(rule, autoRule, index) != null
    }
}

private fun buildAutoTagData(
    speechRule: SpeechRule,
    tag: String,
    oldTagData: Map<String, String>,
    personality: String,
): Map<String, String> {
    val defs = speechRule.tagsData[tag].orEmpty()
    val allowedKeys = defs.map { it.key }.toSet()

    val result = oldTagData.toMutableMap()

    defs.forEach { defTag ->
        val key = defTag.key
        val defaultValue = defTag.value["default"].orEmpty()

        if (defaultValue.isNotBlank() && result[key].isNullOrBlank()) {
            result[key] = defaultValue
        }
    }

    if (allowedKeys.isEmpty() || allowedKeys.contains("personality")) {
        result["personality"] = personality
    }

    return if (allowedKeys.isEmpty()) {
        result
    } else {
        result.filterKeys { it in allowedKeys }
    }
}

private fun normalizeVoiceIdForMatch(raw: String): String {
    return raw
        .trim()
        .removePrefix("clone_")
        .replace(Regex("^ggref_\\d+_"), "")
        .replace(Regex("[()（）\\s/\\\\.:：，,;；#?&=\\[\\]{}]+"), "_")
        .replace(Regex("_+"), "_")
        .trim('_')
        .lowercase()
}

private fun extractCloneVoiceNamesFromPluginCode(code: String): List<String> {
    val markerIndex = code.indexOf("CLONE_VOICE_NAMES")
    if (markerIndex < 0) return emptyList()

    val openIndex = code.indexOf("[", markerIndex)
    if (openIndex < 0) return emptyList()

    val closeIndex = code.indexOf("];", openIndex)
    if (closeIndex < 0) return emptyList()

    val block = code.substring(openIndex + 1, closeIndex)

    return Regex("\"((?:\\\\.|[^\"])*)\"|'((?:\\\\.|[^'])*)'")
        .findAll(block)
        .mapNotNull { match ->
            val value = match.groups[1]?.value ?: match.groups[2]?.value
            value
                ?.replace("\\\"", "\"")
                ?.replace("\\'", "'")
                ?.trim()
                ?.takeIf { it.isNotBlank() }
        }
        .toList()
}

private fun safeVoiceIdAsGgref(name: String, index: Int): String {
    var s = name
        .replace(Regex("[()（）\\s/\\\\.:：，,;；#?&=\\[\\]{}]+"), "_")
        .replace(Regex("_+"), "_")
        .trim('_')

    if (s.length > 70) {
        s = s.substring(0, 70)
    }

    return "ggref_${index}_$s"
}

private fun safeVoiceIdAsClone(name: String): String {
    return "clone_" + name.replace(Regex("[()]"), "_")
}

private fun buildTargetPluginVoiceIds(targetPlugin: Plugin): List<String> {
    val code = targetPlugin.code.toString()
    val names = extractCloneVoiceNamesFromPluginCode(code)
    if (names.isEmpty()) return emptyList()

    val usesGgref = code.contains("ggref_")
    val usesClone = code.contains("clone_")

    val result = mutableListOf<String>()

    names.forEachIndexed { index, name ->
        if (usesGgref) {
            result += safeVoiceIdAsGgref(name, index)
        }

        if (usesClone || !usesGgref) {
            result += safeVoiceIdAsClone(name)
        }

        val cloneId = safeVoiceIdAsClone(name)
        if (cloneId !in result) {
            result += cloneId
        }
    }

    return result.distinct()
}

private fun extractVoiceNumber(raw: String): String {
    val normalized = normalizeVoiceIdForMatch(raw)
    return Regex("\\d{3,4}").find(normalized)?.value.orEmpty()
}

private fun resolveVoiceIdForCurrentPlugin(
    displayName: String,
    oldVoiceId: String,
    targetPlugin: Plugin,
): String {
    val targetVoiceIds = buildTargetPluginVoiceIds(targetPlugin)
    if (targetVoiceIds.isEmpty()) return oldVoiceId

    if (oldVoiceId in targetVoiceIds) return oldVoiceId

    val displayNorm = normalizeVoiceIdForMatch(displayName)
    val oldNorm = normalizeVoiceIdForMatch(oldVoiceId)

    // 1. 优先用配置显示名完整匹配
    targetVoiceIds.firstOrNull { newId ->
        normalizeVoiceIdForMatch(newId) == displayNorm
    }?.let { return it }

    // 2. 用旧 voice 完整匹配
    targetVoiceIds.firstOrNull { newId ->
        normalizeVoiceIdForMatch(newId) == oldNorm
    }?.let { return it }

    // 3. 用显示名里的编号匹配，比如 1060 / 0868 / 1591
    val displayNumber = extractVoiceNumber(displayName)
    if (displayNumber.isNotBlank()) {
        targetVoiceIds.firstOrNull { newId ->
            extractVoiceNumber(newId) == displayNumber
        }?.let { return it }
    }

    // 4. 用旧 voice 里的编号匹配
    val oldNumber = extractVoiceNumber(oldVoiceId)
    if (oldNumber.isNotBlank()) {
        targetVoiceIds.firstOrNull { newId ->
            extractVoiceNumber(newId) == oldNumber
        }?.let { return it }
    }

    // 5. 包含匹配兜底
    targetVoiceIds.firstOrNull { newId ->
        val newNorm = normalizeVoiceIdForMatch(newId)
        displayNorm.isNotBlank() && (displayNorm.contains(newNorm) || newNorm.contains(displayNorm))
    }?.let { return it }

    targetVoiceIds.firstOrNull { newId ->
        val newNorm = normalizeVoiceIdForMatch(newId)
        oldNorm.isNotBlank() && (oldNorm.contains(newNorm) || newNorm.contains(oldNorm))
    }?.let { return it }

    return oldVoiceId
}



private fun resolvePluginSampleRate(targetPlugin: Plugin): Int {
    val code = targetPlugin.code.toString()
    val markerIndex = code.indexOf("getAudioSampleRate")
    if (markerIndex < 0) return 16000

    val area = code.substring(markerIndex, minOf(code.length, markerIndex + 800))
    return Regex("return\\s+(\\d{4,6})")
        .find(area)
        ?.groupValues
        ?.getOrNull(1)
        ?.toIntOrNull()
        ?.takeIf { it > 0 }
        ?: 16000
}

private fun resolvePluginNeedDecode(targetPlugin: Plugin): Boolean {
    val code = targetPlugin.code.toString()
    val markerIndex = code.indexOf("getAudioFormat")
    if (markerIndex < 0) return true

    val area = code.substring(markerIndex, minOf(code.length, markerIndex + 800))
    val format = Regex("return\\s+['\\\"]([^'\\\"]+)['\\\"]")
        .find(area)
        ?.groupValues
        ?.getOrNull(1)
        ?.trim()
        ?.lowercase()
        .orEmpty()

    return when {
        format.contains("raw") -> false
        format.contains("pcm") -> false
        else -> true
    }
}


private fun SystemTtsV2.pluginIdOrEmpty(): String {
    val config = config as? TtsConfigurationDTO ?: return ""
    val source = config.source as? PluginTtsSource ?: return ""
    return source.pluginId
}

private fun flattenGroupOptions(
    nodes: List<GroupTreeNode>,
    level: Int = 0,
): List<GroupMoveOption> {
    return nodes.flatMap { node ->
        listOf(GroupMoveOption(node.group, level)) +
                flattenGroupOptions(node.children, level + 1)
    }
}

private fun flattenSearchTtsResults(
    nodes: List<GroupTreeNode>,
    pluginNameMap: Map<String, String>,
    parentPath: String = "",
): List<SearchTtsResult> {
    return nodes.flatMap { node ->
        val currentPath =
            if (parentPath.isBlank()) node.group.name else "$parentPath / ${node.group.name}"

        node.list.map { tts ->
            val pluginId = tts.pluginIdOrEmpty()

            SearchTtsResult(
                group = node.group,
                groupPath = currentPath,
                pluginName = pluginNameMap[pluginId].orEmpty(),
                pluginId = pluginId,
                tts = tts
            )
        } + flattenSearchTtsResults(
            nodes = node.children,
            pluginNameMap = pluginNameMap,
            parentPath = currentPath
        )
    }
}



