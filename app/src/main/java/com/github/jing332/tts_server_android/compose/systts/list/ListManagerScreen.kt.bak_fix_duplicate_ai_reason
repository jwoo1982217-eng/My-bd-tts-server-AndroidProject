                    }
                }
            )
        }
    }

    fun LazyListScope.batchGroupTreeNode(
        node: GroupTreeNode,
        level: Int = 0,
        parentSelected: Boolean = false,
    ) {
        val g = node.group
        val key = "batch_g_${g.id}"
        val selfSelected = selectedGroupIds.contains(g.id)
        val branchSelected = parentSelected || selfSelected

        stickyHeader(key = key) {
            Row(
                modifier = Modifier
                    .fillMaxWidth()
                    .clickable {
                        vm.updateGroupExpanded(g, !g.isExpanded)
                    }
                    .padding(
                        start = (level * 20).dp,
                        end = 8.dp,
                        top = 6.dp,
                        bottom = 6.dp
                    ),
                verticalAlignment = Alignment.CenterVertically
            ) {
                Checkbox(
                    checked = branchSelected,
                    onCheckedChange = { checked ->
                        val idsInThisGroup = node.collectAllTts().map { it.id }.toSet()

                        selectedGroupIds =
                            if (checked) {
                                selectedGroupIds + g.id
                            } else {
                                selectedGroupIds - g.id
                            }

                        // 重新勾选文件夹时，之前单独取消的音色应恢复选中；
                        // 取消文件夹时，也清理这个分组下的排除状态。
                        excludedTtsIds = excludedTtsIds - idsInThisGroup
                    }
                )

                Text(
                    text = if (g.isExpanded) {
                        "📂 ${g.name}"
                    } else {
                        "📁 ${g.name}"
                    },
                    modifier = Modifier.weight(1f),
                    style = MaterialTheme.typography.titleMedium
                )

                Text(
                    text = if (g.isExpanded) "收起" else "展开",
                    color = MaterialTheme.colorScheme.primary,
                    modifier = Modifier.padding(horizontal = 8.dp)
                )
            }
        }

        if (g.isExpanded) {
            itemsIndexed(
                node.list.sortedBy { it.order },
                key = { _, item -> "batch_${g.id}_${item.id}" }
            ) { _, item ->
                val descriptor = remember(item) {
                    ItemDescriptorFactory.from(context, item)
                }

                val itemSelectedByGroup = branchSelected
                val itemSelectedDirectly = selectedTtsIds.contains(item.id)
                val itemExcluded = excludedTtsIds.contains(item.id)
                val itemSelected = (itemSelectedByGroup && !itemExcluded) || itemSelectedDirectly

                Row(
                    modifier = Modifier
                        .fillMaxWidth()
                        .clickable {
                            if (itemSelectedByGroup) {
                                if (itemExcluded) {
                                    excludedTtsIds = excludedTtsIds - item.id
                                } else {
                                    excludedTtsIds = excludedTtsIds + item.id
                                    selectedTtsIds = selectedTtsIds - item.id
                                }
                            } else {
                                selectedTtsIds =
                                    if (selectedTtsIds.contains(item.id)) {
                                        selectedTtsIds - item.id
                                    } else {
                                        selectedTtsIds + item.id
                                    }
                            }
                        }
                        .padding(
                            start = 8.dp,
                            end = 8.dp,
                            top = 4.dp,
                            bottom = 4.dp
                        ),
                    verticalAlignment = Alignment.CenterVertically
                ) {
                    Checkbox(
                        checked = itemSelected,
                        onCheckedChange = { checked ->
                            if (itemSelectedByGroup) {
                                if (checked) {
                                    excludedTtsIds = excludedTtsIds - item.id
                                } else {
                                    excludedTtsIds = excludedTtsIds + item.id
                                    selectedTtsIds = selectedTtsIds - item.id
                                }
                            } else {
                            selectedTtsIds =
                                if (checked) {
                                    selectedTtsIds + item.id
                                } else {
                                    selectedTtsIds - item.id
                                }
                        }
                        }
                    )

                    Column(
                        modifier = Modifier.weight(1f)
                    ) {
                        Text(
                            text = "🎙️ ${item.displayName}",
                            style = MaterialTheme.typography.bodyLarge
                        )

                        Text(
                            text = listOf(
                                descriptor.tagName,
                                descriptor.bottom
                            ).filter {
                                it.toString().isNotBlank()
                            }.joinToString("  |  "),
                            style = MaterialTheme.typography.bodySmall,
                            color = MaterialTheme.colorScheme.onSurfaceVariant
                        )
                    }
                }
            }

            node.children.forEach { child ->
                batchGroupTreeNode(
                    node = child,
                    level = level + 1,
                    parentSelected = branchSelected
                )
            }
        }
    }

    fun LazyListScope.groupTreeNode(
        node: GroupTreeNode,
        level: Int = 0,
    ) {
        val g = node.group
        val allTts = node.allTts()
        val checkState = allTts.count { it.isEnabled }.sizeToToggleableState(allTts.size)
        val key = "g_${g.id}"

        item(key = key) {
    ShadowedDraggableItem(reorderableState = reorderState, key = key) {
        Row(
            modifier = Modifier
                .fillMaxWidth()
                .detectReorderAfterLongPress(reorderState),
            verticalAlignment = Alignment.CenterVertically
        ) {
            val hasAutoTagButton = autoTagRuleByGroupName(g.name) != null

            if (hasAutoTagButton) {
                IconButton(
                    modifier = Modifier.padding(start = (level * 20).dp),
                    onClick = {
                        autoTagAndSortGroup(node)
                    }
                ) {
                    Text("🏷️")
                }
            }

            Group(
                modifier = Modifier
                    .weight(1f)
                    .padding(start = if (hasAutoTagButton) 0.dp else (level * 20).dp),
                name = g.name,
                isExpanded = g.isExpanded,
                toggleableState = checkState,
                onToggleableStateChange = {
                    vm.updateGroupEnable(node, it)
                },
                onClick = {
                    vm.updateGroupExpanded(g, !g.isExpanded)
                },
                onDelete = {
                    fun deleteNode(target: GroupTreeNode) {
                        target.children.forEach { deleteNode(it) }
                        dbm.systemTtsV2.delete(*target.list.toTypedArray())
                        dbm.systemTtsV2.deleteGroup(target.group)
                    }

                    deleteNode(node)
                },
                onRename = {
                    dbm.systemTtsV2.updateGroup(g.copy(name = it))
                },
                onCopy = {
                    scope.launch {
                        val group = g.copy(
                            id = System.currentTimeMillis(),
                            name = it.ifBlank { context.getString(R.string.unnamed) },
                            parentGroupId = g.parentGroupId
                        )

                        dbm.systemTtsV2.insertGroup(group)

                        dbm.systemTtsV2.getByGroup(g.id)
                            .forEachIndexed { index, tts ->
                                dbm.systemTtsV2.insert(
                                    tts.copy(
                                        id = System.currentTimeMillis() + index,
                                        groupId = group.id
                                    )
                                )
                            }
                    }
                },
                onEditAudioParams = {
                    groupAudioParamsDialog = g
                },
                onEditGroupMembers = {
                    editGroupMembersDialog = node
                },
                onExport = {
                    showGroupExportSheet = node.toExportList()
                },
                onSort = {
                    showSortDialog = node.list
                },
                onAddChildGroup = if (level == 0) {
                    {
                        addGroupParentId = g.id
                        addGroupDialog = true
                    }
                } else {
                    null
                },
                onPromoteToRoot = if (g.parentGroupId != 0L) {
                    {
                        scope.launch {
                            withIO {
                                vm.moveGroupToRoot(g)
                            }
                        }
                    }
                } else {
                    null
                },
                onMoveToParent = if (g.parentGroupId == 0L && models.any { it.group.id != g.id }) {
                    {
                        moveGroupDialog = g
                    }
                } else {
                    null
                }
            )
        }
    }
}

        if (g.isExpanded) {
            itemsIndexed(
                node.list.sortedBy { it.order },
                key = { _, item -> "${g.id}_${item.id}" }
            ) { _, item ->
                ShadowedDraggableItem(
                    reorderableState = reorderState,
                    key = "${g.id}_${item.id}"
                ) {
                    val descriptor = remember(item) {
                        ItemDescriptorFactory.from(context, item)
                    }

                    Item(
                        reorderState = reorderState,
                        modifier = Modifier.padding(
                            start = 8.dp,
                            end = 8.dp,
                            top = 4.dp,
                            bottom = 4.dp
                        ),
                        name = item.displayName,
                        tagName = descriptor.tagName,
                        type = descriptor.type,
                        standby = descriptor.standby,
                        enabled = item.isEnabled,
                        onEnabledChange = {
                            vm.updateTtsEnabled(item, it)
                            if (it) SystemTtsService.notifyUpdateConfig()
                        },
                        desc = descriptor.desc,
                        params = descriptor.bottom,
                        onClick = {
                            showQuickEdit = item
                        },
                        onLongClick = {
                            switchSpeechTarget(item)
                        },
                        onCopy = {
                            navigateToEdit(item.copy(id = System.currentTimeMillis()))
                        },
                        onDelete = {
                            deleteTts = item
                        },
                        onEdit = {
                            navigateToEdit(item)
                        },
                        onAudition = {
                            if (item.config is TtsConfigurationDTO) {
                                showAuditionDialog = item
                            } else {
                                context.toast(R.string.not_support_audition)
                            }
                        },
                        onExport = {
                            showExportSheet = listOf(
                                item.copy(groupId = AbstractListGroup.DEFAULT_GROUP_ID)
                            )
                        }
                    )
                }
            }

            node.children.forEach { child ->
                groupTreeNode(child, level + 1)
            }
        }
    }

    Scaffold(
        modifier = Modifier.nestedScroll(scrollBehavior.nestedScrollConnection),
        topBar = {
            NavTopAppBar(
                scrollBehavior = scrollBehavior,
                title = {
                    if (isSearchMode) {
                        Surface(
                            modifier = Modifier
                                .fillMaxWidth()
                                .height(48.dp)
                                .clip(CircleShape),
                            color = MaterialTheme.colorScheme.surfaceVariant,
                            shape = CircleShape
                        ) {
                            TopSearchField(
                                value = inputSearchKeyword,
                                onValueChange = {
                                    inputSearchKeyword = it
                                }
                            )
                        }
                    } else {
                        Text(
                            if (isBatchEditMode) {
                                "已选择 $selectedCount 项"
                            } else {
                                stringResource(id = R.string.system_tts)
                            }
                        )
                    }
                },
                actions = {
                    if (isBatchEditMode) {
    IconButton(
        enabled = selectedCount > 0,
        onClick = {
            showBatchMoveDialog = true
        }
    ) {
        Text("📦")
    }

    IconButton(
        enabled = selectedCount > 0,
        onClick = {
            showSwitchPluginDialog = true
        }
    ) {
        Text("🔌")
    }

    IconButton(
        enabled = selectedCount > 0,
        onClick = {
            showBatchDeleteDialog = true
        }
    ) {
        Text("🗑")
    }

    TextButton(
        onClick = {
            exitBatchEditMode()
        }
    ) {
        Text("取消")
    }
} else {
                        if (isSearchMode) {
                            IconButton(
                                onClick = {
                                    exitSearchMode()
                                }
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Close,
                                    contentDescription = "关闭"
                                )
                            }
                        } else {
                            IconButton(
                                onClick = {
                                    isFabExpanded = false
                                    isFabTucked = true
                                    isSearchMode = true
                                }
                            ) {
                                Icon(
                                    imageVector = Icons.Default.Search,
                                    contentDescription = "搜索"
                                )
                            }

                            IconButton(onClick = { wrapGroupsDialog = true }) {
                                Text("📚")
                            }

                            IconButton(
                                enabled = !isRestarting,
                                onClick = {
                                    isRestarting = true
                                    scope.launch {
                                        delay(650)
                                        restartApp(context)
                                    }
                                }
                            ) {
                                if (isRestarting) {
                                    CircularProgressIndicator(
                                        modifier = Modifier
                                            .width(22.dp)
                                            .height(22.dp),
                                        strokeWidth = 2.dp
                                    )
                                } else {
                                    Text("🚀")
                                }
                            }

                                                          IconButton(
                                  onClick = {
                                      aiRulePreviewExpanded = false
                                      showAiGenerateConfigDialog = true
                                  }
                              ) {
                                  Text("🤖")
                              }

IconButton(
                                onClick = {
                                    exitSearchMode()
                                    isFabExpanded = false
                                    isFabTucked = true
                                    isBatchEditMode = true
                                }
                            ) {
                                Text("✏️")
                            }

                            IconButton(onClick = { showOptions = true }) {
                                Icon(
                                    Icons.Default.MoreVert,
                                    stringResource(id = R.string.more_options)
                                )
                                MenuMoreOptions(
                                    expanded = showOptions,
                                    onDismissRequest = { showOptions = false },
                                    onExportAll = {
                                        showGroupExportSheet = models.flatMap { it.toExportList() }
                                    },
                                )
                            }
                        }
                    }
                }
            )
        },
    ) { paddingValues ->
        Box(Modifier.padding(top = paddingValues.calculateTopPadding())) {
            ControlBottomBarVisibility(listState, LocalBottomBarBehavior.current)

            LazyColumn(
                Modifier
                    .fillMaxSize()
                    .then(
                        if ((!isSearchMode || inputSearchKeyword.isBlank()) && !isBatchEditMode) {
                            Modifier.reorderable(state = reorderState)
                        } else {
                            Modifier
                        }
                    ),
                state = listState
            ) {
                if (isBatchEditMode) {
                    models.forEach { node ->
                        batchGroupTreeNode(node)
                    }
                } else if (!isSearchMode || inputSearchKeyword.isBlank()) {
                    models.forEach { node ->
                        groupTreeNode(node)
                    }
                } else if (!canSearchInput) {
                    item(key = "search_tip") {
                        Text(
                            text = "🔍 请输入至少 2 个字；数字编号可直接搜索",
                            modifier = Modifier.padding(horizontal = 16.dp, vertical = 8.dp)
                        )
                    }
                } else {
                    item(key = "search_result_count") {
