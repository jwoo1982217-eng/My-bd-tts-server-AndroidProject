private fun restartApp(context: Context) {
    val intent = context.packageManager.getLaunchIntentForPackage(context.packageName)
    if (intent != null) {
        intent.addFlags(Intent.FLAG_ACTIVITY_NEW_TASK or Intent.FLAG_ACTIVITY_CLEAR_TASK)
        context.startActivity(intent)
        exitProcess(0)
    }
}

private fun searchDigitVariants(digits: String): Set<String> {
    val result = mutableSetOf<String>()

    if (digits.isNotBlank()) {
        result.add(digits)

        if (digits.length == 1) {
            result.add(digits.padStart(2, '0'))
        }
    }

    return result
}

private fun SearchTtsResult.matchesSearch(
    context: Context,
    keyword: String,
): Boolean {
    val query = keyword.trim().lowercase()
    if (query.isEmpty()) return false

    if (
        group.name.lowercase().contains(query) ||
        groupPath.lowercase().contains(query) ||
        tts.displayName.lowercase().contains(query) ||
        pluginName.lowercase().contains(query) ||
        pluginId.lowercase().contains(query)
    ) {
        return true
    }

    val descriptor = ItemDescriptorFactory.from(context, tts)
    val isPureNumber = query.all { it.isDigit() }

    if (isPureNumber) {
        val variants = searchDigitVariants(query)

        val fields = listOf(
            group.name,
            groupPath,
            tts.displayName,
            pluginName,
            pluginId,
            descriptor.tagName,
            descriptor.desc,
            descriptor.bottom
        )

        return fields.any { field ->
            val text = field.toString()
            val lower = text.lowercase()
            val digitsOnly = text.filter { it.isDigit() }

            variants.any { v ->
                lower.contains(v) || digitsOnly.contains(v)
            }
        }
    }

    return listOf(
        pluginName,
        pluginId,
        descriptor.tagName,
        descriptor.type,
        descriptor.standby,
        descriptor.desc,
        descriptor.bottom
    ).any {
        it.toString().lowercase().contains(query)
    }
}

